# Supabase Postgres pooled connection string (Transaction mode / pgbouncer)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase direct connection string for migrations (Session mode)
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# Wallet-auth JWT secret (set a strong random value in non-local envs)
AUTH_JWT_SECRET="replace-me-with-a-long-random-secret"

# Solana network config
NEXT_PUBLIC_SOLANA_NETWORK="devnet"
# Optional custom RPC endpoint
# NEXT_PUBLIC_SOLANA_RPC_ENDPOINT="https://api.devnet.solana.com"
